# Groq API key — get one free at https://console.groq.com/keys
GROQ_API_KEY=gsk_your-key-here

# Must be at least 32 random characters. Generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace-this-with-a-long-random-string

# Port the server listens on (most hosts set this automatically)
PORT=3000

# Admin account, created automatically on first run
ADMIN_EMAIL=your@email.com
ADMIN_PASSWORD=choose-a-strong-password

# Comma-separated list of origins allowed to call the API
# (set this to your live URL once deployed)
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
